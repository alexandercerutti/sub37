{
	"name": "@sub37/adapter-utils",
	"version": "0.0.0",
	"description": "Utilities to build adapters",
	"main": "lib/index.js",
	"type": "module",
	"scripts": {
		"build": "rm -rf lib && pnpm tsc --build --force",
		"test": "pnpm build && pnpm -C ../.. run test",
		"prepublishOnly": "pnpm build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alexandercerutti/sub37.git"
	},
	"author": "Alexander P. Cerutti <cerutti.alexander@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/alexandercerutti/sub37/issues"
	},
	"homepage": "https://github.com/alexandercerutti/sub37#readme",
	"files": [
		"lib/**/*.+(js|d.ts)!(*.map)"
	],
	"exports": {
		".": {
			"default": "./lib/index.js",
			"types": "./lib/index.d.ts"
		},
		"./MissingContentError": {
			"default": "./lib/MissingContentError.js",
			"types": "./lib/MissingContentError.d.ts"
		},
		"./CueNode": {
			"default": "./lib/CueNode.js",
			"types": "./lib/CudeNode.d.ts"
		},
		"./Entities": {
			"default": "./lib/Entities/index.js",
			"types": "./lib/Entities/index.d.ts"
		},
		"./RenderingModifiers": {
			"default": "./lib/RenderingModifiers.js",
			"types": "./lib/RenderingModifiers.d.ts"
		},
		"./Errors": {
			"default": "./lib/Errors/index.js",
			"types": "./lib/Errors/index.d.ts"
		},
		"./BaseAdapter": {
			"default": "./lib/BaseAdapter/index.js",
			"types": "./lib/BaseAdapter/index.d.ts"
		},
		"./Region": {
			"types": "./lib/Region.d.ts"
		}
	}
}
