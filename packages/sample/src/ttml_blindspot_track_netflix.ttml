			<p begin="4435265000t" end="4453207508t" region="region_00" tts:extent="35.00% 5.33%" tts:origin="30.00% 79.29%" xml:id="subtitle284">So every single</p>
			<p begin="4435265000t" end="4453207508t" region="region_01" tts:extent="37.50% 5.33%" tts:origin="30.00% 84.62%" xml:id="subtitle285">government agent</p>
			<p begin="4453625008t" end="4486567501t" region="region_00" tts:extent="67.50% 5.33%" tts:origin="15.00% 79.29%" xml:id="subtitle286">is now a potential target...</p>
			<p begin="4453625008t" end="4486567501t" region="region_01" tts:extent="30.00% 5.33%" tts:origin="32.50% 84.62%" xml:id="subtitle287">including us.</p>
